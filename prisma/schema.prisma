// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  price         Int
  stockQuantity Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id                  String   @id @default(uuid())
  razorpayOrderId     String   @unique
  razorpayPaymentId   String?
  customerDetails     Json     // Stores shipping name, email, phone, address, etc.
  productId           String?  // Optional reference for single product tracking
  items               Json     // Stores full checkout items list for multi-product orders
  amount              Int      // Total amount in INR
  status              String   @default("pending") // pending, paid, failed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
